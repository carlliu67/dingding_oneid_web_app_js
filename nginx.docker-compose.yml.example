# /usr/local/nginx-docker/docker-compose.yml
version: '3.8'

services:
  nginx:
    image: nginx:latest
    container_name: nginx-prod
    restart: always
    ports:
      - "7000:7000"  # 前端端口映射：主机7000 → 容器7000
      - "7001:7001"  # 后端端口映射：主机7001 → 容器7001
    volumes:
      - ./conf/nginx.conf:/etc/nginx/nginx.conf
      - ./html:/usr/share/nginx/html
      - ./logs:/var/log/nginx
    networks:
      - nginx-network

networks:
  nginx-network:
    driver: bridge